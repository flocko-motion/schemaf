# Regenerate with: ./schemaf.sh codegen
#
# schemaf.sh — thin shell wrapper around the Go CLI.
#
# ARCHITECTURE: This script is a dispatcher only. All logic belongs in Go
# (cli/cmd/*/). The shell handles only what must happen before Go runs:
# finding the project root, loading env vars, and delegating to `go run`.
# Do not add application logic here — implement it as a Go subcommand.
set -euo pipefail

if [ ! -f "$(dirname "$0")/schemaf.toml" ]; then
  echo "ERROR: schemaf.toml not found in the same directory as this script."
  echo "       Place schemaf.sh next to your schemaf.toml — see schemaf documentation."
  exit 1
fi

ORIG_PWD="$PWD"
PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$PROJECT_ROOT"

# Load project name from schemaf.toml.
PROJECT_NAME=$(grep '^name' schemaf.toml | cut -d= -f2 | tr -d ' "')

# Load secrets from ~/.<name>/dev/etc/env.
# Only sets variables that are not already in the environment.
_schemaf_load_env() {
  local envfile="$1"
  [ -f "$envfile" ] || return 0
  while IFS='=' read -r key val; do
    key=$(echo "$key" | xargs)
    [ -z "$key" ] || [[ "$key" == \#* ]] && continue
    val=$(echo "$val" | xargs)
    if [ -z "${!key:-}" ]; then
      export "$key=$val"
    fi
  done < "$envfile"
}
_schemaf_load_env "$HOME/.${PROJECT_NAME}/dev/etc/env"

SCHEMAF_VER=$(cd go && go list -m -f '{{"{{"}}.Version{{"}}"}}' github.com/flocko-motion/schemaf 2>/dev/null || echo "unknown")
echo "schemaf ${SCHEMAF_VER} — ${PROJECT_NAME}"

CMD="${1:-}"
shift 2>/dev/null || true

case "$CMD" in
  codegen)
    exec go run github.com/flocko-motion/schemaf/cmd/schemaf codegen all
    ;;
  test)
    go run github.com/flocko-motion/schemaf/cmd/schemaf codegen all

    # Start ephemeral test environment (no volumes — all data discarded after tests).
    docker compose -f gen/compose.test.yml up -d --wait

    # Query the random host port Docker assigned to postgres:5432.
    PG_PORT=$(docker compose -f gen/compose.test.yml port postgres 5432 | awk -F: '{print $NF}')
    export DATABASE_URL="postgres://schemaf:dev@localhost:${PG_PORT}/${PROJECT_NAME}?sslmode=disable"

    # Set URL env vars for project sidecar services (generated by codegen).
    # shellcheck source=/dev/null
    source gen/test-env.sh

    # Run tests, capture exit code, then tear down regardless of result.
    go run github.com/flocko-motion/schemaf/cmd/schemaf test "$@"
    TEST_EXIT=$?
    docker compose -f gen/compose.test.yml down
    exit $TEST_EXIT
    ;;
  run)
    if [ ! -f gen/compose.gen.yml ]; then
      echo "gen/ not found — running codegen first..."
      go run github.com/flocko-motion/schemaf/cmd/schemaf codegen all
    fi
    exec docker compose -f gen/compose.gen.yml up "$@"
    ;;
  dev)
    exec go run "${PROJECT_ROOT}/go" dev "$@"
    ;;
  upgrade)
    TARGET="${1:-}"
    if [ -z "$TARGET" ]; then
      # Query GitHub for the latest tag instead of Go proxy (which caches @latest for ~30min).
      TARGET=$(git ls-remote --tags --sort=-v:refname https://github.com/flocko-motion/schemaf.git 'v*' \
        | head -1 | sed 's|.*/||')
      if [ -z "$TARGET" ]; then
        echo "ERROR: could not determine latest version from GitHub" >&2
        exit 1
      fi
    fi
    echo "Upgrading schemaf framework to ${TARGET}..."
    cd go
    OLD_VER=$(go list -m -f '{{"{{"}}.Version{{"}}"}}' github.com/flocko-motion/schemaf 2>/dev/null || echo "unknown")
    go get "github.com/flocko-motion/schemaf@${TARGET}"
    NEW_VER=$(go list -m -f '{{"{{"}}.Version{{"}}"}}' github.com/flocko-motion/schemaf)
    cd ..
    if [ "$OLD_VER" = "$NEW_VER" ]; then
      echo "Already at ${NEW_VER}"
    else
      echo "Upgraded: $OLD_VER → $NEW_VER"
    fi
    echo "Running codegen..."
    exec go run github.com/flocko-motion/schemaf/cmd/schemaf codegen all
    ;;
  *)
    SCHEMAF_CWD="$ORIG_PWD" exec go run "${PROJECT_ROOT}/go" "$CMD" "$@"
    ;;
esac
