#!/bin/bash
# Code generated by schemaf codegen. DO NOT EDIT.
# Regenerate with: ./schemaf.sh codegen
#
# schemaf.sh — runnable entrypoint for your project CLI.
# Delegates to `go run` so your compiled binary doesn't need to exist yet.
# Both framework commands (codegen, test, run, dev) and custom subcommands
# registered via app.AddSubcommand() in main.go are available through this script.
#
# To add custom commands, use app.AddSubcommand() in your Go code.
# Do not add case branches here. See INSTALL.md and EXTEND.md for documentation.
set -euo pipefail

if [ ! -f "$(dirname "$0")/schemaf.toml" ]; then
  echo "ERROR: schemaf.toml not found in the same directory as this script."
  echo "       Place schemaf.sh next to your schemaf.toml — see schemaf documentation."
  exit 1
fi

ORIG_PWD="$PWD"
PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$PROJECT_ROOT"

# Load project name from schemaf.toml.
PROJECT_NAME=$(grep '^name' schemaf.toml | cut -d= -f2 | tr -d ' "')

# Load secrets from ~/.<name>/dev/etc/env.
# Only sets variables that are not already in the environment.
_schemaf_load_env() {
  local envfile="$1"
  [ -f "$envfile" ] || return 0
  while IFS='=' read -r key val; do
    key=$(echo "$key" | xargs)
    [ -z "$key" ] || [[ "$key" == \#* ]] && continue
    val=$(echo "$val" | xargs)
    if [ -z "${!key:-}" ]; then
      export "$key=$val"
    fi
  done < "$envfile"
}
_schemaf_load_env "$HOME/.${PROJECT_NAME}/dev/etc/env"

# Check if a port is in use. If so, offer to kill the blocking process.
# Usage: _schemaf_check_port <port> <service_name>
_schemaf_check_port() {
  local port="$1" name="$2"
  local pid
  pid=$(lsof -ti :"$port" 2>/dev/null | head -1) || true
  [ -z "$pid" ] && return 0

  local proc
  proc=$(ps -p "$pid" -o comm= 2>/dev/null || echo "unknown")
  echo "Port $port is in use by $proc (PID $pid) — needed for $name." >&2
  printf "Kill it? [y/N] " >&2
  read -r answer
  if [[ "$answer" =~ ^[Yy]$ ]]; then
    kill "$pid" 2>/dev/null
    sleep 0.5
    if lsof -ti :"$port" >/dev/null 2>&1; then
      kill -9 "$pid" 2>/dev/null
      sleep 0.3
    fi
    echo "Killed." >&2
  else
    echo "ERROR: Port $port is required for $name. Aborting." >&2
    exit 1
  fi
}

SCHEMAF_VER=$(cd go && go list -m -f '{{"{{"}}.Version{{"}}"}}' github.com/flocko-motion/schemaf 2>/dev/null || echo "unknown")
echo "schemaf ${SCHEMAF_VER} — ${PROJECT_NAME}"

CMD="${1:-}"
shift 2>/dev/null || true

case "$CMD" in
  codegen)
    exec go run github.com/flocko-motion/schemaf/cmd/schemaf codegen all
    ;;
  test)
    go run github.com/flocko-motion/schemaf/cmd/schemaf codegen all

    # Start ephemeral test environment (no volumes — all data discarded after tests).
    docker compose -f gen/compose.test.yml up -d --wait

    # Query the random host port Docker assigned to postgres:5432.
    PG_PORT=$(docker compose -f gen/compose.test.yml port postgres 5432 | awk -F: '{print $NF}')
    export DATABASE_URL="postgres://schemaf:dev@localhost:${PG_PORT}/${PROJECT_NAME}?sslmode=disable"

    # Set URL env vars for project sidecar services (generated by codegen).
    # shellcheck source=/dev/null
    source gen/test-env.sh

    # Run tests, capture exit code, then tear down regardless of result.
    go run github.com/flocko-motion/schemaf/cmd/schemaf test "$@"
    TEST_EXIT=$?
    docker compose -f gen/compose.test.yml down
    exit $TEST_EXIT
    ;;
  run)
    if [ ! -f gen/compose.gen.yml ]; then
      echo "gen/ not found — running codegen first..."
      go run github.com/flocko-motion/schemaf/cmd/schemaf codegen all
    fi
    exec docker compose -f gen/compose.gen.yml up "$@"
    ;;
  dev)
    if [ ! -f gen/compose.gen.yml ]; then
      echo "gen/ not found — running codegen first..."
      go run github.com/flocko-motion/schemaf/cmd/schemaf codegen all
    fi
    SERVICES="${1:-}"
    shift 2>/dev/null || true
    COMPOSE="docker compose -f gen/compose.gen.yml -f gen/compose.dev.yml"

    # No args: show available services.
    if [ -z "$SERVICES" ]; then
      echo "Usage: ./schemaf.sh dev <service>[,<service>,...]"
      echo ""
      echo "Services:"
      echo "  db              Postgres database"
      echo "  infrastructure  Postgres + project compose services"
      echo "  backend         Go server on :7000"
      echo "  frontend        Vite dev server on :7002"
      echo "  all             All of the above"
      echo ""
      echo "Combine with commas: ./schemaf.sh dev db,backend"
      exit 0
    fi

    # Parse comma-separated list of services.
    RUN_DB=false
    RUN_INFRA=false
    RUN_BACKEND=false
    RUN_FRONTEND=false
    IFS=',' read -ra PARTS <<< "$SERVICES"
    for part in "${PARTS[@]}"; do
      case "$(echo "$part" | xargs)" in
        db)             RUN_DB=true ;;
        infrastructure) RUN_INFRA=true ;;
        backend)        RUN_BACKEND=true ;;
        frontend)       RUN_FRONTEND=true ;;
        all)            RUN_DB=true; RUN_INFRA=true; RUN_BACKEND=true; RUN_FRONTEND=true ;;
        *)              echo "Unknown dev service: $part" >&2
                        echo "Available: db, infrastructure, backend, frontend, all" >&2
                        exit 1 ;;
      esac
    done

    # Start Docker services.
    if $RUN_INFRA; then
      $COMPOSE up --scale backend=0 -d --wait "$@"
    elif $RUN_DB; then
      $COMPOSE up postgres -d --wait "$@"
    fi

    # Warn if backend requested but postgres isn't running.
    if $RUN_BACKEND && ! $RUN_DB && ! $RUN_INFRA; then
      if ! $COMPOSE ps postgres --status running -q 2>/dev/null | grep -q .; then
        echo "WARNING: postgres is not running — backend may fail to connect." >&2
        echo "         Start it with: ./schemaf.sh dev db" >&2
      fi
    fi

    # Check ports before starting.
    if $RUN_BACKEND; then
      _schemaf_check_port 7000 "backend"
    fi
    if $RUN_FRONTEND; then
      _schemaf_check_port 7002 "frontend"
      if [ ! -d frontend ]; then
        echo "ERROR: frontend/ directory not found. Run ./schemaf.sh codegen first." >&2
        exit 1
      fi
    fi

    # Start frontend dev server.
    if $RUN_FRONTEND; then
      if $RUN_BACKEND; then
        (cd frontend && npm run dev) &
        FRONTEND_PID=$!
        trap "kill $FRONTEND_PID 2>/dev/null" EXIT
        # Give Vite a moment to bind — fail fast if it crashes.
        sleep 1
        if ! kill -0 "$FRONTEND_PID" 2>/dev/null; then
          echo "ERROR: frontend dev server failed to start." >&2
          exit 1
        fi
      else
        exec sh -c 'cd frontend && npm run dev'
      fi
    fi

    # Start Go server (foreground).
    if $RUN_BACKEND; then
      exec go run ./go server
    fi
    ;;
  upgrade)
    TARGET="${1:-}"
    if [ -z "$TARGET" ]; then
      # Query GitHub for the latest tag instead of Go proxy (which caches @latest for ~30min).
      TARGET=$(git ls-remote --tags --sort=-v:refname https://github.com/flocko-motion/schemaf.git 'v*' \
        | head -1 | sed 's|.*/||')
      if [ -z "$TARGET" ]; then
        echo "ERROR: could not determine latest version from GitHub" >&2
        exit 1
      fi
    fi
    echo "Upgrading schemaf framework to ${TARGET}..."
    cd go
    OLD_VER=$(go list -m -f '{{"{{"}}.Version{{"}}"}}' github.com/flocko-motion/schemaf 2>/dev/null || echo "unknown")
    go get "github.com/flocko-motion/schemaf@${TARGET}"
    NEW_VER=$(go list -m -f '{{"{{"}}.Version{{"}}"}}' github.com/flocko-motion/schemaf)
    cd ..
    if [ "$OLD_VER" = "$NEW_VER" ]; then
      echo "Already at ${NEW_VER}"
    else
      echo "Upgraded: $OLD_VER → $NEW_VER"
    fi
    echo "Running codegen..."
    exec go run github.com/flocko-motion/schemaf/cmd/schemaf codegen all
    ;;
  *)
    SCHEMAF_CWD="$ORIG_PWD" exec go run "${PROJECT_ROOT}/go" "$CMD" "$@"
    ;;
esac
