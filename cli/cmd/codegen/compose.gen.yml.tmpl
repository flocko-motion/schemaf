# Code generated by schemaf codegen. DO NOT EDIT.
# Regenerate with: ./schemaf.sh codegen
# Run via: ./schemaf.sh run   (or dev)

name: {{.Name}}
{{if .Extensions}}
include:
{{- range .Extensions}}
  - {{.}}
{{- end}}
{{end}}
services:
  postgres:
    image: postgres:17-alpine
    container_name: {{.Name}}-postgres
    environment:
      POSTGRES_USER: schemaf
      POSTGRES_PASSWORD: ${DB_PASS:-dev}
      POSTGRES_DB: {{.Name}}
    volumes:
      - postgres-data:/var/lib/postgresql/data
    networks:
      - net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U schemaf -d {{.Name}}"]
      interval: 5s
      timeout: 5s
      retries: 10
      start_period: 10s
    restart: unless-stopped

  backend:
    build:
      context: .
      dockerfile: Dockerfile.gen
    container_name: {{.Name}}-backend
    environment:
      SCHEMAF_ENV: docker
      DB_PASS: ${DB_PASS:-dev}
      PORT: "7000"
      BACKUP_SSH_HOST: ${BACKUP_SSH_HOST:-}
      BACKUP_SSH_PORT: ${BACKUP_SSH_PORT:-22}
      BACKUP_SSH_USER: ${BACKUP_SSH_USER:-}
      BACKUP_SSH_KEY: /run/secrets/backup_key
      BACKUP_PATH: ${BACKUP_PATH:-/backups}
      BACKUP_RETAIN: ${BACKUP_RETAIN:-30}
      BACKUP_HOUR: ${BACKUP_HOUR:-3}
    secrets:
      - backup_key
    networks:
      - net
    depends_on:
      postgres:
        condition: service_healthy
    restart: unless-stopped

secrets:
  backup_key:
    file: ${BACKUP_SSH_KEY_PATH:-/dev/null}

networks:
  net:
    driver: bridge
    name: {{.Name}}-net

volumes:
  postgres-data:
    name: {{.Name}}-postgres-data
